# TabVault — Environment Variables
# Copy this file to .env and fill every value before starting the application.
# Never commit .env to git — it is listed in .gitignore.
#
# How to use:
#   cp .env.example .env
#   Fill every placeholder value below, then run: docker compose up -d

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Spring profile to activate (development | staging | production)
SPRING_PROFILES_ACTIVE=development

# Port the Spring Boot backend listens on
SERVER_PORT=8080

# ---------------------------------------------------------------------------
# Database — PostgreSQL
# Values here must match the docker-compose.yml POSTGRES_* environment vars.
# ---------------------------------------------------------------------------

# JDBC URL for the local Docker PostgreSQL instance
# Format: jdbc:postgresql://<host>:<port>/<database>
DATABASE_URL=jdbc:postgresql://localhost:5432/tabvault

# PostgreSQL username (must match POSTGRES_USER in docker-compose.yml)
DATABASE_USERNAME=tabvault

# PostgreSQL password (must match POSTGRES_PASSWORD in docker-compose.yml)
DATABASE_PASSWORD=tabvault_dev_password

# ---------------------------------------------------------------------------
# Cache — Redis
# ---------------------------------------------------------------------------

# Redis connection URL for the local Docker Redis instance
# Format: redis://<host>:<port>
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Authentication — JWT
# ---------------------------------------------------------------------------

# 64-character hex secret for signing JWT tokens.
# Generate with: openssl rand -hex 64
# REQUIRED — backend will fail to start if absent.
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_64

# Access token expiry in minutes (default: 15)
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15

# Refresh token expiry in days (default: 7)
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ---------------------------------------------------------------------------
# LLM — Claude API (Anthropic)
# ---------------------------------------------------------------------------

# Anthropic API key.
# Obtain at: https://console.anthropic.com → API Keys → Create Key
# Ensure your key has access to the claude-sonnet-4 model.
# REQUIRED for Phase 2+ (LLM integration). Phase 1 works without it.
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# Claude model identifier used for all LLM calls
CLAUDE_MODEL=claude-sonnet-4-5

# ---------------------------------------------------------------------------
# Content Extraction — YouTube Data API
# ---------------------------------------------------------------------------

# YouTube Data API v3 key.
# Obtain at: https://console.cloud.google.com → Library → "YouTube Data API v3"
# → Enable → Credentials → Create Credentials → API Key
# REQUIRED for Phase 3+ (YouTube transcript extraction).
YOUTUBE_API_KEY=REPLACE_WITH_YOUR_YOUTUBE_API_KEY

# ---------------------------------------------------------------------------
# Push Notifications — VAPID (Web Push)
# ---------------------------------------------------------------------------

# VAPID public key (URL-safe base64, no padding).
# Generate once per environment with: npx web-push generate-vapid-keys
# Share the PUBLIC key with browser clients — it is not secret.
VAPID_PUBLIC_KEY=REPLACE_WITH_VAPID_PUBLIC_KEY

# VAPID private key (URL-safe base64, no padding).
# NEVER share or commit this value. Generate alongside the public key above.
# REQUIRED for Phase 2+ (push notifications). Backend fails to start if absent.
VAPID_PRIVATE_KEY=REPLACE_WITH_VAPID_PRIVATE_KEY

# VAPID contact URI — included in push request headers per RFC 8292.
# Use the project owner's email address.
VAPID_SUBJECT=mailto:wu.tsan@northeastern.edu

# Reminder dispatch cron — schedule for the daily push notification job (MOD-005).
# Default: 08:00 UTC every day. Uses Spring cron format: second minute hour day month weekday.
REMINDER_DISPATCH_CRON=0 0 8 * * ?

# Auto-cleanup cron — schedule for the daily staleness-check and auto-archive job (MOD-006).
# Default: 09:00 UTC every day. Uses Quartz cron format (7 fields).
AUTO_CLEANUP_CRON=0 0 9 * * ?

# ---------------------------------------------------------------------------
# File Uploads
# ---------------------------------------------------------------------------

# Absolute or relative path to the local upload directory.
# Create this directory before starting: mkdir -p ./uploads
UPLOAD_DIR=./uploads

# ---------------------------------------------------------------------------
# CORS — Frontend Origins
# Comma-separated list of allowed origins for the REST API.
# ---------------------------------------------------------------------------

# Local PWA dashboard dev server
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
