# TabVault Chrome Extension — Environment Variables
#
# Copy this file to .env.local before running `npm run dev` or `npm run build`.
# Values here are substituted at build time by Vite (VITE_ prefix required).

# Backend API base URL.
# Default: http://localhost:8080 (used when this variable is absent).
# Set to your production API URL for production builds.
VITE_API_BASE_URL=http://localhost:8080
